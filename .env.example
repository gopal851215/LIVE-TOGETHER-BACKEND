# Backend Environment Variables

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/live-together?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars
NODE_ENV=production

# Email (for receipts/reset - optional, use console.log if not set)
EMAIL_HOST=smtp.gmail.com
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=LIVE-TOGETHER <noreply@yourdomain.com>

# Frontend URL (update CORS)
CLIENT_URL=https://your-frontend.vercel.app

# Google OAuth (if used)
GOOGLE_CLIENT_ID=your-google-client-id.googleusercontent.com

